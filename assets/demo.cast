[1.014, "o", "# joshua-agent demo — FastAPI Task Manager\r\n# Agents named after WarGames characters:\r\n#   Falken (dev), Jennifer (bug-hunter), McKittrick (qa gate)\r\n\r\nproject:\r\n  name: task-manager-api\r\n  path: /tmp/joshua-demo\r\n\r\nrunner:\r\n  type: custom\r\n  command: \"bash /tmp/joshua-demo/mock-runner.sh {prompt_file}\"\r\n  timeout: 60\r\n\r\nagents:\r\n  falken:\r\n    skill: dev\r\n    tasks:\r\n      - \"Fix SQL injection in all endpoints using parameterized queries\"\r\n      - \"Refactor authentication middleware for cleaner session handling\"\r\n  jennifer:\r\n    skill: bug-hunter\r\n    tasks:\r\n      - \"Find and fix hardcoded secrets and missing input validation\"\r\n      - \"Scan for connection leaks and missing error handling\"\r\n  mckittrick:\r\n    skill: qa\r\n\r\nsprint:\r\n  max_cycles: 2\r\n  cycle_sleep: 1\r\n  gate_blocking: true\r\n  cross_agent_context: true\r\n  git_strategy: none\r\n\r\nmemory:\r\n  enabled: false\r\n"]
[3.009, "o", "\r\n$ cat app.py\r\n"]
[1.011, "o", "\"\"\"FastAPI Task Manager — intentionally vulnerable for joshua-agent demo.\"\"\"\r\nimport sqlite3\r\nfrom fastapi import FastAPI\r\n\r\napp = FastAPI(title=\"Task Manager API\")\r\n\r\nSECRET_KEY = \"sk-prod-a1b2c3d4e5f6\"  # VULNERABLE: hardcoded secret\r\n\r\ndef get_db():\r\n    return sqlite3.connect(\"tasks.db\")\r\n\r\n@app.get(\"/tasks/{task_id}\")\r\ndef get_task(task_id: str):\r\n    db = get_db()\r\n    # VULNERABLE: SQL injection\r\n    row = db.execute(f\"SELECT * FROM tasks WHERE id = {task_id}\").fetchone()\r\n    return {\"task\": row}\r\n\r\n@app.post(\"/tasks\")\r\nasync def create_task(title: str):\r\n    # VULNERABLE: no input validation, no length check\r\n    db = get_db()\r\n    db.execute(f\"INSERT INTO tasks (title) VALUES ('{title}')\")\r\n    db.commit()\r\n    return {\"status\": \"created\"}\r\n\r\n@app.delete(\"/tasks/{task_id}\")\r\ndef delete_task(task_id: str):\r\n    db = get_db()\r\n    db.execute(f\"DELETE FROM tasks WHERE id = {task_id}\")\r\n    db.commit()\r\n    return {\"status\": \"deleted\"}\r\n\r\nif __name__ == \"__main__\":\r\n    import uvicorn\r\n    uvicorn.run"]
[0.000, "o", "(app, host=\"0.0.0.0\", port=8000, debug=True)\r\n"]
[3.006, "o", "\r\n$ joshua run config.yaml -n 2\r\n"]
