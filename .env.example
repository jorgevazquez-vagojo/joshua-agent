# joshua-agent environment variables
# Copy to .env and fill in your values

# LLM API Keys (at least one required)
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...

# Server authentication
# Single admin token (legacy):
JOSHUA_AUTH_TOKEN=your-secret-token-here
# Multi-role tokens (JSON, overrides JOSHUA_AUTH_TOKEN if set):
# JOSHUA_TOKENS={"admin-token": "admin", "ops-token": "operator", "view-token": "viewer"}

# Git integrations
GITHUB_TOKEN=ghp_...
GITLAB_TOKEN=glpat-...

# Database (optional — defaults to SQLite)
# JOSHUA_DB_URL=redis://localhost:6379/0
# JOSHUA_DB_URL=postgresql://user:pass@localhost:5432/joshua

# Notifications (optional)
# SLACK_WEBHOOK=https://hooks.slack.com/services/...
# DISCORD_WEBHOOK=https://discord.com/api/webhooks/...
